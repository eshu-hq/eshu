# Copy this file to .env.remote-e2e on the VPN/EC2 test machine and replace
# the sample values with the account, region, state object, ECR repository, and
# allowlisted GitHub repository you want to prove.
#
# The default corpus profile is smoke-safe so collector-specific proofs can
# start from checked-in fixtures. For an inner-loop representative gate, set
# corpus mode to representative and point ESHU_FILESYSTEM_HOST_ROOT at a
# cloned 20-50 repository corpus. For a release/full-corpus gate, set corpus
# mode to full, point ESHU_FILESYSTEM_HOST_ROOT at the absolute corpus path,
# and set a non-zero minimum or exact expected repository count.

ESHU_REMOTE_E2E_CORPUS_MODE=smoke
ESHU_REMOTE_E2E_MIN_REPOSITORY_COUNT=0
ESHU_REMOTE_E2E_MAX_REPOSITORY_COUNT=
ESHU_REMOTE_E2E_EXPECTED_REPOSITORY_COUNT=
ESHU_FILESYSTEM_HOST_ROOT=./tests/fixtures/ecosystems
ESHU_CANONICAL_WRITE_TIMEOUT=120s
ESHU_CODE_CALL_PROJECTION_PARTITION_COUNT=4
ESHU_CODE_CALL_PROJECTION_WORKERS=2
ESHU_REPO_DEPENDENCY_PROJECTION_WORKERS=4
ESHU_WORKFLOW_COORDINATOR_RECONCILE_INTERVAL=30s
ESHU_WORKFLOW_COORDINATOR_RUN_RECONCILE_INTERVAL=30s
ESHU_API_KEY=
ESHU_REMOTE_E2E_ADVISORY_EVIDENCE_CVE_ID=
ESHU_REMOTE_E2E_DERIVED_TARGET_LIMIT=100
ESHU_REMOTE_E2E_MIN_PACKAGE_COUNT=
ESHU_REMOTE_E2E_MIN_ADVISORY_EVIDENCE_COUNT=
ESHU_REMOTE_E2E_MIN_IMPACT_FINDING_COUNT=
ESHU_REMOTE_E2E_MIN_SECURITY_ALERT_RECONCILIATION_COUNT=
ESHU_REMOTE_E2E_MIN_SBOM_ATTACHMENT_COUNT=
ESHU_REMOTE_E2E_MIN_CONTAINER_IMAGE_IDENTITY_COUNT=
ESHU_REMOTE_E2E_TFSTATE_STATE_MISSING_MAX=0
ESHU_REMOTE_E2E_READBACK_PROOF=
# Comma-separated hosted collector rows that are intentionally unsupported in
# this Compose proof. Leave blank for an all-collector prerelease gate.
# The checked-in remote Compose profile does not start pagerduty, jira,
# grafana, prometheus_mimir, loki, or tempo by default; absent rendered services
# are classified as skipped unless an operator-local profile enables them.
# Do not list an enabled service here to hide missing source facts.
ESHU_REMOTE_E2E_UNSUPPORTED_HOSTED_COLLECTORS=
# Comma-separated reducer rows that are intentionally unsupported in this
# Compose proof. Unsupported rows make the manifest partial, not pass.
ESHU_REMOTE_E2E_UNSUPPORTED_REDUCERS=

ESHU_AWS_E2E_ACCOUNT_ID=123456789012
ESHU_AWS_E2E_REGION=us-east-1
ESHU_AWS_E2E_SERVICES=iam,ecr,ecs,ec2,elbv2,lambda,eks,route53,sqs,sns,eventbridge,s3,rds,dynamodb,cloudwatchlogs,cloudfront,apigateway,secretsmanager,ssm
ESHU_AWS_FRESHNESS_TOKEN=remote-e2e-freshness-token-change-me
ESHU_AWS_REDACTION_KEY=remote-e2e-aws-redaction-key-32-bytes-min

ESHU_TFSTATE_S3_BUCKET=example-terraform-state
ESHU_TFSTATE_S3_KEY=prod/app/terraform.tfstate
ESHU_TFSTATE_S3_REGION=us-east-1
ESHU_TFSTATE_REDACTION_KEY=remote-e2e-tfstate-redaction-key-32-bytes
ESHU_TFSTATE_REDACTION_RULESET_VERSION=remote-e2e-v1

ESHU_ECR_OCI_REGISTRY_ID=123456789012
ESHU_ECR_OCI_REGION=us-east-1
ESHU_ECR_OCI_REPOSITORY=team/api

ESHU_VULNERABILITY_E2E_CVE_ID=CVE-2021-44228
ESHU_NVD_API_KEY=

ESHU_SBOM_ATTESTATION_E2E_SUBJECT_DIGEST=sha256:1111111111111111111111111111111111111111111111111111111111111111
ESHU_SBOM_ATTESTATION_DOCUMENT_URL=http://sbom-attestation-fixture:8080/cyclonedx_image_subject.json
ESHU_SCANNER_WORKER_SBOM_HOST_ROOT=./tests/fixtures/ecosystems
ESHU_SCANNER_WORKER_SBOM_SUBJECT_DIGEST=sha256:1111111111111111111111111111111111111111111111111111111111111111

ESHU_SECURITY_ALERT_REPOSITORY=owner/repository
ESHU_SECURITY_ALERT_GITHUB_TOKEN=replace-with-read-only-token

# Optional PagerDuty profile values. Leave disabled unless running
# `--profile pagerduty` with private, read-only operator-local credentials.
ESHU_REMOTE_E2E_PAGERDUTY_ENABLED=false
ESHU_PAGERDUTY_ACCOUNT_ID=
ESHU_PAGERDUTY_API_TOKEN=
ESHU_PAGERDUTY_API_BASE_URL=
ESHU_PAGERDUTY_SOURCE_URI=
ESHU_PAGERDUTY_INCIDENT_LOOKBACK=24h
ESHU_PAGERDUTY_INCIDENT_LIMIT=1
ESHU_PAGERDUTY_LOG_ENTRY_LIMIT=1
ESHU_PAGERDUTY_CHANGE_EVENT_LIMIT=1
ESHU_PAGERDUTY_CONFIG_VALIDATION_ENABLED=true
ESHU_PAGERDUTY_CONFIG_RESOURCE_LIMIT=2

# Optional Jira profile values. Leave disabled unless running `--profile jira`
# with private, read-only operator-local credentials.
ESHU_REMOTE_E2E_JIRA_ENABLED=false
ESHU_JIRA_SITE_ID=
ESHU_JIRA_BASE_URL=
ESHU_JIRA_EMAIL=
ESHU_JIRA_API_TOKEN=
# Referenced by the Jira collector through jql_env, so normal JQL with spaces
# and operators does not need JSON escaping inside ESHU_COLLECTOR_INSTANCES_JSON.
ESHU_JIRA_JQL=
ESHU_JIRA_UPDATED_LOOKBACK=168h
ESHU_JIRA_ISSUE_LIMIT=1
ESHU_JIRA_CHANGELOG_LIMIT=25
ESHU_JIRA_REMOTE_LINK_LIMIT=25
ESHU_JIRA_METADATA_LIMIT=25

# Optional Grafana profile values. Leave disabled unless running
# `--profile grafana` with private, read-only operator-local credentials.
ESHU_REMOTE_E2E_GRAFANA_ENABLED=false
ESHU_GRAFANA_BASE_URL=
ESHU_GRAFANA_TOKEN=
ESHU_GRAFANA_RESOURCE_LIMIT=25
ESHU_GRAFANA_STALE_AFTER=24h

# Optional Prometheus/Mimir profile values. Leave disabled unless running
# `--profile prometheus-mimir` with private operator-local targets. Set
# ESHU_PROMETHEUS_MIMIR_TOKEN_ENV=PROMETHEUS_MIMIR_TOKEN only when the target
# requires a bearer token; unauthenticated Prometheus targets can leave it blank.
ESHU_REMOTE_E2E_PROMETHEUS_MIMIR_ENABLED=false
ESHU_PROMETHEUS_MIMIR_PROVIDER=prometheus
ESHU_PROMETHEUS_MIMIR_BASE_URL=
ESHU_PROMETHEUS_MIMIR_PATH_PREFIX=
ESHU_PROMETHEUS_MIMIR_TOKEN_ENV=
ESHU_PROMETHEUS_MIMIR_TOKEN=
ESHU_PROMETHEUS_MIMIR_TENANT_ID_ENV=
ESHU_PROMETHEUS_MIMIR_TENANT_ID=
ESHU_PROMETHEUS_MIMIR_RESOURCE_LIMIT=25
ESHU_PROMETHEUS_MIMIR_STALE_AFTER=24h

# Optional Loki profile values. Leave disabled unless running `--profile loki`
# with private operator-local targets. Set ESHU_LOKI_TOKEN_ENV=LOKI_TOKEN only
# when the target requires a bearer token.
ESHU_REMOTE_E2E_LOKI_ENABLED=false
ESHU_LOKI_BASE_URL=
ESHU_LOKI_PATH_PREFIX=
ESHU_LOKI_TOKEN_ENV=
ESHU_LOKI_TOKEN=
ESHU_LOKI_TENANT_ID_ENV=
ESHU_LOKI_TENANT_ID=
ESHU_LOKI_RESOURCE_LIMIT=25
ESHU_LOKI_LABEL_VALUE_NAMES_JSON=[]
ESHU_LOKI_MAX_LABEL_VALUES_PER_LABEL=5
ESHU_LOKI_SERIES_MATCHERS_JSON=[]
ESHU_LOKI_STALE_AFTER=24h

# Optional Tempo profile values. Leave disabled unless running `--profile tempo`
# with private operator-local targets. Set ESHU_TEMPO_TOKEN_ENV=TEMPO_TOKEN only
# when the target requires a bearer token.
ESHU_REMOTE_E2E_TEMPO_ENABLED=false
ESHU_TEMPO_BASE_URL=
ESHU_TEMPO_PATH_PREFIX=
ESHU_TEMPO_TOKEN_ENV=
ESHU_TEMPO_TOKEN=
ESHU_TEMPO_TENANT_ID_ENV=
ESHU_TEMPO_TENANT_ID=
ESHU_TEMPO_RESOURCE_LIMIT=25
ESHU_TEMPO_TAG_VALUE_NAMES_JSON=[]
ESHU_TEMPO_MAX_TAG_VALUES_PER_TAG=5
ESHU_TEMPO_STALE_AFTER=24h
ESHU_TEMPO_FRESHNESS_PROBE_ENABLED=true
ESHU_TEMPO_LOOKBACK=2h

# Optional Confluence profile values. Leave blank unless running
# `--profile confluence`. The profile runs a one-shot preflight before the
# collector starts; set ESHU_CONFLUENCE_BASE_URL, read-only credentials, and
# exactly one bounded selector: ESHU_CONFLUENCE_SPACE_ID,
# ESHU_CONFLUENCE_SPACE_IDS, or ESHU_CONFLUENCE_ROOT_PAGE_ID.
ESHU_CONFLUENCE_BASE_URL=
ESHU_CONFLUENCE_SPACE_ID=
ESHU_CONFLUENCE_SPACE_IDS=
ESHU_CONFLUENCE_ROOT_PAGE_ID=
ESHU_CONFLUENCE_BEARER_TOKEN=
ESHU_CONFLUENCE_EMAIL=
ESHU_CONFLUENCE_API_TOKEN=
