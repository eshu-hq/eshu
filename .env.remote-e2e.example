# Copy this file to .env.remote-e2e on the VPN/EC2 test machine and replace
# the sample values with the account, region, state object, ECR repository, and
# allowlisted GitHub repository you want to prove.
#
# The default corpus profile is smoke-safe so collector-specific proofs can
# start from checked-in fixtures. For an inner-loop representative gate, set
# corpus mode to representative and point ESHU_FILESYSTEM_HOST_ROOT at a
# cloned 20-50 repository corpus. For a release/full-corpus gate, set corpus
# mode to full, point ESHU_FILESYSTEM_HOST_ROOT at the absolute corpus path,
# and set a non-zero minimum or exact expected repository count.

ESHU_REMOTE_E2E_CORPUS_MODE=smoke
ESHU_REMOTE_E2E_MIN_REPOSITORY_COUNT=0
ESHU_REMOTE_E2E_MAX_REPOSITORY_COUNT=
ESHU_REMOTE_E2E_EXPECTED_REPOSITORY_COUNT=
ESHU_FILESYSTEM_HOST_ROOT=./tests/fixtures/ecosystems
ESHU_CANONICAL_WRITE_TIMEOUT=120s
ESHU_WORKFLOW_COORDINATOR_RECONCILE_INTERVAL=30s
ESHU_WORKFLOW_COORDINATOR_RUN_RECONCILE_INTERVAL=30s
ESHU_API_KEY=
ESHU_REMOTE_E2E_ADVISORY_EVIDENCE_CVE_ID=
ESHU_REMOTE_E2E_DERIVED_TARGET_LIMIT=100
ESHU_REMOTE_E2E_MIN_PACKAGE_COUNT=
ESHU_REMOTE_E2E_MIN_ADVISORY_EVIDENCE_COUNT=
ESHU_REMOTE_E2E_MIN_IMPACT_FINDING_COUNT=
ESHU_REMOTE_E2E_MIN_SECURITY_ALERT_RECONCILIATION_COUNT=
ESHU_REMOTE_E2E_MIN_SBOM_ATTACHMENT_COUNT=
ESHU_REMOTE_E2E_MIN_CONTAINER_IMAGE_IDENTITY_COUNT=
ESHU_REMOTE_E2E_READBACK_PROOF=
# Comma-separated hosted collector rows that are intentionally unsupported in
# this Compose proof. Leave blank for an all-collector prerelease gate.
ESHU_REMOTE_E2E_UNSUPPORTED_HOSTED_COLLECTORS=
# Comma-separated reducer rows that are intentionally unsupported in this
# Compose proof. Unsupported rows make the manifest partial, not pass.
ESHU_REMOTE_E2E_UNSUPPORTED_REDUCERS=

ESHU_AWS_E2E_ACCOUNT_ID=123456789012
ESHU_AWS_E2E_REGION=us-east-1
ESHU_AWS_E2E_SERVICES=iam,ecr,ecs,ec2,elbv2,lambda,eks,route53,sqs,sns,eventbridge,s3,rds,dynamodb,cloudwatchlogs,cloudfront,apigateway,secretsmanager,ssm
ESHU_AWS_FRESHNESS_TOKEN=remote-e2e-freshness-token-change-me
ESHU_AWS_REDACTION_KEY=remote-e2e-aws-redaction-key-32-bytes-min

ESHU_TFSTATE_S3_BUCKET=example-terraform-state
ESHU_TFSTATE_S3_KEY=prod/app/terraform.tfstate
ESHU_TFSTATE_S3_REGION=us-east-1
ESHU_TFSTATE_REDACTION_KEY=remote-e2e-tfstate-redaction-key-32-bytes
ESHU_TFSTATE_REDACTION_RULESET_VERSION=remote-e2e-v1

ESHU_ECR_OCI_REGISTRY_ID=123456789012
ESHU_ECR_OCI_REGION=us-east-1
ESHU_ECR_OCI_REPOSITORY=team/api

ESHU_VULNERABILITY_E2E_CVE_ID=CVE-2021-44228
ESHU_NVD_API_KEY=

ESHU_SBOM_ATTESTATION_E2E_SUBJECT_DIGEST=sha256:1111111111111111111111111111111111111111111111111111111111111111
ESHU_SBOM_ATTESTATION_DOCUMENT_URL=http://sbom-attestation-fixture:8080/cyclonedx_image_subject.json

ESHU_SECURITY_ALERT_REPOSITORY=owner/repository
ESHU_SECURITY_ALERT_GITHUB_TOKEN=replace-with-read-only-token

# Optional Confluence profile values. Leave blank unless running
# `--profile confluence`.
ESHU_CONFLUENCE_BASE_URL=
ESHU_CONFLUENCE_SPACE_ID=
ESHU_CONFLUENCE_SPACE_IDS=
ESHU_CONFLUENCE_ROOT_PAGE_ID=
ESHU_CONFLUENCE_BEARER_TOKEN=
ESHU_CONFLUENCE_EMAIL=
ESHU_CONFLUENCE_API_TOKEN=
