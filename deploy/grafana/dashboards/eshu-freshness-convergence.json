      "title": "Generation Convergence",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "description": "Generation lifecycle state counts (active, pending, completed, superseded, failed) from runtime /admin/status. Watch pending and failed trending up: convergence is stalling.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum by (state) (eshu_runtime_generation_total{service_name=~\"$service\"})",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "title": "Generation State Totals",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "description": "Scope activity from the latest collector observation: active scopes, scopes that changed (need re-projection), and unchanged scopes (refresh skipped). High changed counts drive downstream freshness work.",
