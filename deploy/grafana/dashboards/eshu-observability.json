          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "histogram_quantile(0.95, sum by (le, db_operation) (rate(eshu_neo4j_query_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{db_operation}}",
