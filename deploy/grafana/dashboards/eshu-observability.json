        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(increase(eshu_hidden_dirs_skipped_total[$__range]))",
          "refId": "A"
