      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "limit": 20,
        "showTraceId": true
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "query": "{ resource.service.name = \"eshu-api\" }",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Recent API Traces",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service_name=~\"eshu-(api|indexer)\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Eshu Logs",
      "type": "logs"
