      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum by (eshu_tool_name) (rate(eshu_mcp_tool_calls_total[$__rate_interval]))",
          "legendFormat": "{{eshu_tool_name}}",
          "refId": "A"
        }
      ],
      "title": "MCP Tool Call Rate",
