{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "poolSizeValue": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string" }
      ]
    },
    "durationValue": {
      "type": "string"
    },
    "postgresConnectionTuning": {
      "type": "object",
      "properties": {
        "maxOpenConns": { "$ref": "#/definitions/poolSizeValue" },
        "maxIdleConns": { "$ref": "#/definitions/poolSizeValue" },
        "connMaxLifetime": { "$ref": "#/definitions/durationValue" },
        "connMaxIdleTime": { "$ref": "#/definitions/durationValue" },
        "pingTimeout": { "$ref": "#/definitions/durationValue" }
      }
    },
    "neo4jConnectionTuning": {
      "type": "object",
      "properties": {
        "maxConnectionPoolSize": { "$ref": "#/definitions/poolSizeValue" },
        "maxConnectionLifetime": { "$ref": "#/definitions/durationValue" },
        "connectionAcquisitionTimeout": { "$ref": "#/definitions/durationValue" },
        "socketConnectTimeout": { "$ref": "#/definitions/durationValue" },
        "verifyTimeout": { "$ref": "#/definitions/durationValue" }
      }
    },
    "connectionTuning": {
      "type": "object",
      "properties": {
        "postgres": { "$ref": "#/definitions/postgresConnectionTuning" },
        "neo4j": { "$ref": "#/definitions/neo4jConnectionTuning" }
      }
    },
    "collectorInstances": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "instance_id": { "type": "string" },
          "collector_kind": { "type": "string" },
          "mode": { "type": "string" },
          "enabled": { "type": "boolean" },
          "bootstrap": { "type": "boolean" },
          "claims_enabled": { "type": "boolean" },
          "display_name": { "type": "string" },
          "configuration": {}
        },
        "required": ["instance_id", "collector_kind", "mode", "enabled", "claims_enabled"],
        "additionalProperties": false
      }
    },
    "secretEnv": {
      "type": "array",
      "items": { "type": "object" }
    },
    "networkPolicyPeer": {
      "type": "object",
      "properties": {
        "namespaceSelector": { "type": "object" },
        "podSelector": { "type": "object" },
        "ipBlock": { "type": "object" }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "networkPolicyPort": {
      "type": "object",
      "properties": {
        "protocol": {
          "type": "string",
          "enum": ["TCP", "UDP", "SCTP"]
        },
        "port": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 65535 },
            { "type": "string" }
          ]
        }
      },
      "required": ["port"],
      "additionalProperties": false
    },
    "networkPolicyEgressRule": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "to": {
          "type": "array",
          "items": { "$ref": "#/definitions/networkPolicyPeer" }
        },
        "ports": {
          "type": "array",
          "items": { "$ref": "#/definitions/networkPolicyPort" }
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "LoadBalancer", "NodePort"]
        },
        "port": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "properties": {
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer", "minimum": 1 },
        "runAsGroup": { "type": "integer", "minimum": 1 },
        "fsGroup": { "type": "integer", "minimum": 1 },
        "fsGroupChangePolicy": {
          "type": "string",
          "enum": ["OnRootMismatch", "Always"]
        },
        "seccompProfile": {
          "type": "object",
          "properties": {
            "type": { "type": "string" }
          }
        }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "properties": {
        "allowPrivilegeEscalation": { "type": "boolean" },
        "readOnlyRootFilesystem": { "type": "boolean" },
        "capabilities": {
          "type": "object",
          "properties": {
            "drop": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "initContainerSecurityContext": {
      "type": "object",
      "properties": {
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer", "minimum": 0 },
        "runAsGroup": { "type": "integer", "minimum": 0 },
        "allowPrivilegeEscalation": { "type": "boolean" },
        "readOnlyRootFilesystem": { "type": "boolean" },
        "capabilities": {
          "type": "object",
          "properties": {
            "drop": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "schemaBootstrap": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "useHelmHooks": { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "serviceAccountName": { "type": "string" },
        "annotations": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "resources": { "type": "object" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "egress": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["broad", "restricted"]
            },
            "dns": { "$ref": "#/definitions/networkPolicyEgressRule" },
            "datastores": { "$ref": "#/definitions/networkPolicyEgressRule" },
            "graph": { "$ref": "#/definitions/networkPolicyEgressRule" },
            "internalServices": { "$ref": "#/definitions/networkPolicyEgressRule" },
            "classes": {
              "type": "object",
              "properties": {
                "api": { "$ref": "#/definitions/networkPolicyEgressRule" },
                "mcp": { "$ref": "#/definitions/networkPolicyEgressRule" },
                "repoSync": { "$ref": "#/definitions/networkPolicyEgressRule" },
                "collectorProviders": { "$ref": "#/definitions/networkPolicyEgressRule" },
                "semanticProviders": { "$ref": "#/definitions/networkPolicyEgressRule" },
                "extensions": { "$ref": "#/definitions/networkPolicyEgressRule" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "apiAuth": {
      "type": "object",
      "properties": {
        "secretName": { "type": "string" },
        "key": { "type": "string" }
      }
    },
    "resolutionEngine": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "lanes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
              },
              "domains": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "replicas": { "type": "integer", "minimum": 0 },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
              "resources": { "type": "object" }
            },
            "required": ["name", "domains"],
            "additionalProperties": false
          }
        },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      }
    },
    "workflowCoordinator": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "deploymentMode": {
          "type": "string",
          "enum": ["dark", "active"]
        },
        "claimsEnabled": { "type": "boolean" },
        "collectorInstances": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "instance_id": { "type": "string" },
              "collector_kind": { "type": "string" },
              "mode": { "type": "string" },
              "enabled": { "type": "boolean" },
              "bootstrap": { "type": "boolean" },
              "claims_enabled": { "type": "boolean" },
              "display_name": { "type": "string" },
              "configuration": {}
            },
            "required": ["instance_id", "collector_kind", "mode", "enabled"],
            "additionalProperties": false
          }
        },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "extraVolumes": { "type": "array", "items": { "type": "object" } },
        "extraVolumeMounts": { "type": "array", "items": { "type": "object" } },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      }
    },
    "webhookListener": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "maxBodyBytes": { "type": "integer", "minimum": 1 },
        "defaultBranch": { "type": "string" },
        "github": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "path": { "type": "string" },
            "secretName": { "type": "string" },
            "secretKey": { "type": "string" }
          }
        },
        "gitlab": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "path": { "type": "string" },
            "secretName": { "type": "string" },
            "tokenKey": { "type": "string" }
          }
        },
        "bitbucket": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "path": { "type": "string" },
            "secretName": { "type": "string" },
            "secretKey": { "type": "string" }
          }
        },
        "awsFreshness": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "path": { "type": "string" },
            "secretName": { "type": "string" },
            "tokenKey": { "type": "string" }
          }
        },
        "pagerDuty": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "path": { "type": "string" },
            "secretName": { "type": "string" },
            "secretKey": { "type": "string" },
            "scopeId": { "type": "string" }
          }
        },
        "jira": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "path": { "type": "string" },
            "secretName": { "type": "string" },
            "secretKey": { "type": "string" },
            "scopeId": { "type": "string" }
          }
        },
        "exposure": {
          "type": "object",
          "properties": {
            "ingress": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "className": { "type": "string" },
                "annotations": { "type": "object" },
                "hosts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "host": { "type": "string" }
                    },
                    "required": ["host"],
                    "additionalProperties": false
                  }
                },
                "tls": { "type": "array" }
              },
              "additionalProperties": false
            }
          }
        },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      }
    },
    "confluenceCollector": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "baseUrl": { "type": "string" },
        "spaceId": { "type": "string" },
        "spaceIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "spaceKey": { "type": "string" },
        "rootPageId": { "type": "string" },
        "pageLimit": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string" }
          ]
        },
        "pollInterval": { "type": "string" },
        "credentials": {
          "type": "object",
          "properties": {
            "secretName": { "type": "string" },
            "emailKey": { "type": "string" },
            "apiTokenKey": { "type": "string" },
            "bearerTokenKey": { "type": "string" }
          }
        },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      }
    },
    "ociRegistryCollector": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "instanceId": { "type": "string" },
        "pollInterval": { "type": "string" },
        "targets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["jfrog", "ecr", "dockerhub", "ghcr"]
              },
              "registry": { "type": "string" },
              "base_url": { "type": "string" },
              "repository_key": { "type": "string" },
              "repository": { "type": "string" },
              "region": { "type": "string" },
              "registry_id": { "type": "string" },
              "registry_host": { "type": "string" },
              "references": {
                "type": "array",
                "items": { "type": "string" }
              },
              "tag_limit": { "type": "integer", "minimum": 0 },
              "visibility": { "type": "string" },
              "auth_mode": { "type": "string" },
              "source_uri": { "type": "string" },
              "username_env": { "type": "string" },
              "password_env": { "type": "string" },
              "bearer_token_env": { "type": "string" },
              "aws_profile": { "type": "string" },
              "fencing_token": { "type": "integer" }
            },
            "required": ["provider", "repository"],
            "additionalProperties": false
          }
        },
        "aws": {
          "type": "object",
          "properties": {
            "region": { "type": "string" }
          }
        },
        "extraEnv": {
          "type": "array",
          "items": { "type": "object" }
        },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": { "const": true }
            }
          },
          "then": {
            "properties": {
              "targets": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "terraformStateCollector": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "instanceId": { "type": "string" },
        "pollInterval": { "type": "string" },
        "claimLeaseTTL": { "type": "string" },
        "heartbeatInterval": { "type": "string" },
        "sourceMaxBytes": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        },
        "collectorInstances": { "$ref": "#/definitions/collectorInstances" },
        "redaction": {
          "type": "object",
          "properties": {
            "secretName": { "type": "string" },
            "keyKey": { "type": "string" },
            "rulesetVersion": { "type": "string" },
            "sensitiveKeys": { "type": "string" }
          }
        },
        "extraEnv": { "$ref": "#/definitions/secretEnv" },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } } },
          "then": {
            "properties": {
              "collectorInstances": { "minItems": 1 },
              "instanceId": { "minLength": 1 },
              "redaction": {
                "properties": {
                  "secretName": { "minLength": 1 },
                  "keyKey": { "minLength": 1 },
                  "rulesetVersion": { "minLength": 1 }
                },
                "required": ["secretName", "keyKey", "rulesetVersion"]
              }
            }
          }
        }
      ]
    },
    "awsCloudCollector": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "instanceId": { "type": "string" },
        "pollInterval": { "type": "string" },
        "claimLeaseTTL": { "type": "string" },
        "heartbeatInterval": { "type": "string" },
        "collectorInstances": { "$ref": "#/definitions/collectorInstances" },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" },
            "annotations": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "redaction": {
          "type": "object",
          "properties": {
            "secretName": { "type": "string" },
            "keyKey": { "type": "string" }
          }
        },
        "extraEnv": { "$ref": "#/definitions/secretEnv" },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } } },
          "then": {
            "properties": {
              "collectorInstances": { "minItems": 1 },
              "instanceId": { "minLength": 1 }
            }
          }
        }
      ]
    },
    "gcpCloudCollector": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "instanceId": { "type": "string" },
        "pollInterval": { "type": "string" },
        "claimLeaseTTL": { "type": "string" },
        "heartbeatInterval": { "type": "string" },
        "collectorInstances": { "$ref": "#/definitions/collectorInstances" },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" },
            "annotations": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "redaction": {
          "type": "object",
          "properties": {
            "secretName": { "type": "string" },
            "keyKey": { "type": "string" },
            "mountPath": { "type": "string" }
          }
        },
        "extraEnv": { "$ref": "#/definitions/secretEnv" },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } } },
          "then": {
            "properties": {
              "collectorInstances": { "minItems": 1 },
              "instanceId": { "minLength": 1 },
              "redaction": {
                "properties": {
                  "secretName": { "minLength": 1 },
                  "keyKey": { "minLength": 1 },
                  "mountPath": { "minLength": 1 }
                },
                "required": ["secretName", "keyKey", "mountPath"]
              }
            }
          }
        }
      ]
    },
    "azureCloudCollector": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "instanceId": { "type": "string" },
        "pollInterval": { "type": "string" },
        "claimLeaseTTL": { "type": "string" },
        "heartbeatInterval": { "type": "string" },
        "collectorInstances": { "$ref": "#/definitions/collectorInstances" },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" },
            "annotations": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "redaction": {
          "type": "object",
          "properties": {
            "secretName": { "type": "string" },
            "keyKey": { "type": "string" },
            "mountPath": { "type": "string" }
          }
        },
        "extraEnv": { "$ref": "#/definitions/secretEnv" },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } } },
          "then": {
            "properties": {
              "collectorInstances": { "minItems": 1 },
              "instanceId": { "minLength": 1 },
              "redaction": {
                "properties": {
                  "secretName": { "minLength": 1 },
                  "keyKey": { "minLength": 1 },
                  "mountPath": { "minLength": 1 }
                },
                "required": ["secretName", "keyKey", "mountPath"]
              }
            }
          }
        }
      ]
    },
    "packageRegistryCollector": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "instanceId": { "type": "string" },
        "pollInterval": { "type": "string" },
        "claimLeaseTTL": { "type": "string" },
        "heartbeatInterval": { "type": "string" },
        "collectorInstances": { "$ref": "#/definitions/collectorInstances" },
        "extraEnv": { "$ref": "#/definitions/secretEnv" },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } } },
          "then": {
            "properties": {
              "collectorInstances": { "minItems": 1 },
              "instanceId": { "minLength": 1 }
            }
          }
        }
      ]
    },
    "vulnerabilityIntelligenceCollector": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "instanceId": { "type": "string" },
        "pollInterval": { "type": "string" },
        "claimLeaseTTL": { "type": "string" },
        "heartbeatInterval": { "type": "string" },
        "collectorInstances": { "$ref": "#/definitions/collectorInstances" },
        "extraEnv": { "$ref": "#/definitions/secretEnv" },
        "connectionTuning": { "$ref": "#/definitions/connectionTuning" },
        "resources": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } } },
          "then": {
            "properties": {
              "collectorInstances": { "minItems": 1 },
              "instanceId": { "minLength": 1 }
            }
          }
        }
      ]
