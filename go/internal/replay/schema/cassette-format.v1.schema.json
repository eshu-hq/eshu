{
  "$defs": {
    "fact": {
      "additionalProperties": false,
      "properties": {
        "collector_kind": {
          "type": "string"
        },
        "fact_kind": {
          "minLength": 1,
          "type": "string"
        },
        "fencing_token": {
          "minimum": 0,
          "type": "integer"
        },
        "is_tombstone": {
          "type": "boolean"
        },
        "payload": {
          "type": "object"
        },
        "schema_version": {
          "minLength": 1,
          "type": "string"
        },
        "source_confidence": {
          "type": "string"
        },
        "source_record_id": {
          "type": "string"
        },
        "source_uri": {
          "type": "string"
        },
        "stable_fact_key": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "fact_kind",
        "stable_fact_key",
        "schema_version",
        "payload"
      ],
      "type": "object"
    },
    "scope": {
      "additionalProperties": false,
      "properties": {
        "collector_kind": {
          "minLength": 1,
          "type": "string"
        },
        "facts": {
          "items": {
            "$ref": "#/$defs/fact"
          },
          "type": "array"
        },
        "generation_id": {
          "minLength": 1,
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "observed_at": {
          "format": "date-time",
          "type": "string"
        },
        "partition_key": {
          "type": "string"
        },
        "scope_id": {
          "minLength": 1,
          "type": "string"
        },
        "scope_kind": {
          "minLength": 1,
          "type": "string"
        },
        "source_system": {
          "minLength": 1,
          "type": "string"
        },
        "trigger_kind": {
          "type": "string"
        }
      },
      "required": [
        "scope_id",
        "source_system",
        "scope_kind",
        "collector_kind",
        "generation_id",
        "observed_at"
      ],
      "type": "object"
    }
  },
  "$id": "https://eshu.dev/schemas/replay/cassette-format/v1/cassette.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "collector": {
      "type": "string"
    },
    "schema_version": {
      "const": "1"
    },
    "scopes": {
      "items": {
        "$ref": "#/$defs/scope"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "scopes"
  ],
  "title": "Eshu Replay Cassette Format v1",
  "type": "object"
}
