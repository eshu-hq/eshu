# Berkshelf Berksfile for the platform cookbook set. Each `cookbook` with an
# explicit `git:` source names the cookbook-owning repository. The acme-base
# cookbook is sourced from the in-corpus deployable-source repository, which
# makes this repo DEPENDS_ON deployable-source. This mirrors the
# package-consumption (rc-3), Ansible role (rc-30) and Puppet module (rc-32)
# DEPENDS_ON edges but expressed through Chef cookbook resolution, exercising
# the CHEF_COOKBOOK_DEPENDENCY evidence path in the B-7 gate.

source 'https://supermarket.chef.io'

# A Supermarket-only cookbook (no git source) must NOT produce a repository edge:
# the emitter only resolves cookbooks with an explicit git URL. It is placed
# before the git-backed cookbook on purpose, so the per-declaration parser is
# exercised — a naive cross-line match would mis-attribute acme-base's git source
# to it.
cookbook 'nginx', '~> 12.0'

cookbook 'acme-base',
  git: 'https://github.com/acme/deployable-source',
  branch: 'main'
